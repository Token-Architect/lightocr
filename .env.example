# LightOCR Service configuration template
# Copy this file to .env and fill in real values

# “Doubao-Seed-1.6｜251015“ API base URL
OCR_SERVICE_URL=https://ark.cn-beijing.volces.com/api/v3

# “Doubao-Seed-1.6｜251015“ API key
OCR_API_KEY=your-api-key

# “Doubao-Seed-1.6｜251015“ model id
OCR_MODEL_NAME=your-model-id

# Public base URL for this service
# Replace with your deploy target IP/domain and port
# http://localhost:7778 example for local dev
SERVICE_BASE_URL=http://目标ip:目标端口

# File retention days in output/
CLEANUP_RETENTION_DAYS=3

# Optional runtime limits (recommended for laptops/desktops)
# Limit process CPU by core affinity percentage (100 = no limit)
OCR_CPU_LIMIT_PERCENT=80

# Limit OCR task concurrency (2 = balanced default)
OCR_MAX_CONCURRENT_TASKS=2

# Limit OpenCV/native compute threads (0 = library default)
OCR_MAX_THREADS=2

# Limit per-PDF page concurrency for VLM mode
OCR_MAX_WORKERS=3
